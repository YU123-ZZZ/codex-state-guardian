setlocal EnableExtensions
chcp 65001 >nul
cd /d "%~dp0"
set "GUARDIAN_SELF=%~f0"
set "TEMP_PS1=%TEMP%\chatgpt-codex-state-guardian-%RANDOM%-%RANDOM%.ps1"
set "ERR=0"

powershell -NoProfile -ExecutionPolicy Bypass -Command "$self=$env:GUARDIAN_SELF; $tempPs1=$env:TEMP_PS1; $marker='#__CHATGPT_CODEX_GUARDIAN_PS1_BASE64__'; $lines=Get-Content -LiteralPath $self; $index=[Array]::LastIndexOf($lines, $marker); if ($index -lt 0) { Write-Error 'Payload marker not found.'; exit 1 }; $base64=($lines[($index + 1)..($lines.Length - 1)] -join ''); $bytes=[Convert]::FromBase64String($base64); $text=[Text.Encoding]::UTF8.GetString($bytes); Set-Content -LiteralPath $tempPs1 -Value $text -Encoding UTF8"
