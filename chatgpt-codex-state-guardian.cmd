del /q "%TEMP_PS1%" >nul 2>nul

if not "%ERR%"=="0" goto run_failed
if "%~1"=="" goto pause_then_exit
goto exit_now

:run_failed
echo.
echo [ChatGPT(Codex) Guardian] Run failed. Exit code: %ERR%
