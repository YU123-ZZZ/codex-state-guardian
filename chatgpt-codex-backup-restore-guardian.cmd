@echo off
setlocal EnableExtensions
chcp 65001 >nul
cd /d "%~dp0"
set "GUARDIAN_SELF=%~f0"
set "TEMP_PS1=%TEMP%\chatgpt-codex-backup-restore-guardian-%RANDOM%-%RANDOM%.ps1"
set "ERR=0"

powershell -NoProfile -ExecutionPolicy Bypass -Command "$self=$env:GUARDIAN_SELF; $tempPs1=$env:TEMP_PS1; $marker='#__CHATGPT_CODEX_GUARDIAN_PS1_BASE64__'; $lines=Get-Content -LiteralPath $self; $index=[Array]::LastIndexOf($lines, $marker); if ($index -lt 0) { Write-Error 'Payload marker not found.'; exit 1 }; $base64=($lines[($index + 1)..($lines.Length - 1)] -join ''); $bytes=[Convert]::FromBase64String($base64); $text=[Text.Encoding]::UTF8.GetString($bytes); [IO.File]::WriteAllText($tempPs1,$text,[Text.UTF8Encoding]::new($true))"
if errorlevel 1 goto extract_failed

powershell -NoProfile -ExecutionPolicy Bypass -File "%TEMP_PS1%" %*
set "ERR=%ERRORLEVEL%"
del /q "%TEMP_PS1%" >nul 2>nul

if not "%ERR%"=="0" goto run_failed
if "%~1"=="" goto pause_then_exit
goto exit_now

:run_failed
echo.
echo [Guardian] Run failed. Exit code: %ERR%
if "%~1"=="" goto pause_then_exit
goto exit_now

:pause_then_exit
echo.
pause

:exit_now
exit /b %ERR%

:extract_failed
echo [Guardian] Failed to unpack embedded PowerShell payload.
exit /b 1

#__CHATGPT_CODEX_GUARDIAN_PS1_BASE64__

